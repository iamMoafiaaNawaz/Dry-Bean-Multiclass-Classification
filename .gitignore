# ==============================================================
# Dry Bean Classification — .gitignore
# ==============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
.venv/
venv/
ENV/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Data files — do not commit raw datasets to version control
data/*.csv
data/*.xlsx
data/*.xls
data/*.zip

# Trained model artefacts — regenerate with train.py
models/*.joblib
models/*.pkl
models/*.png

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.log

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.*

# Docker
.dockerignore